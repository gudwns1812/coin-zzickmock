        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (stream, result) (rate(sse_send_duration_seconds_sum{job=\"$backend_job\"}[$__rate_interval])) / clamp_min(sum by (stream, result) (rate(sse_send_duration_seconds_count{job=\"$backend_job\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{stream}} {{result}} avg",
          "refId": "A"
        },
        {
          "expr": "max by (stream, result) (sse_send_duration_seconds_max{job=\"$backend_job\"})",
          "legendFormat": "{{stream}} {{result}} max",
          "refId": "B"
