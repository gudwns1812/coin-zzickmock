# Copy to .env only when local defaults need to change.
APP_ENV=local

# Host ports
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=http://localhost/grafana/
LOKI_PORT=3100
MYSQL_PORT=3306
REDIS_PORT=6379

# Local-only credentials. Do not reuse these values outside local development.
MYSQL_ROOT_PASSWORD=test1234
MYSQL_DATABASE=coin_zzickmock
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Backend runtime settings
BACKEND_CPUS=2.0
BACKEND_MEMORY_LIMIT=1g
BACKEND_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=65.0 -XX:InitialRAMPercentage=25.0 -XX:+ExitOnOutOfMemoryError
BITGET_WEBSOCKET_ENABLED=true
MARKET_HISTORY_REPAIR_QUEUE_KEY=coin:market:history-repair:events
MARKET_HISTORY_REPAIR_WORKER_ENABLED=true
MARKET_HISTORY_REPAIR_WORKER_FIXED_DELAY_MS=1000
MARKET_HISTORY_REPAIR_WORKER_BLOCK_TIMEOUT_MS=2000
MARKET_HISTORY_REPAIR_PERSISTENCE_RETRY_MAX_ATTEMPTS=5
MARKET_HISTORY_REPAIR_PERSISTENCE_RETRY_DELAY_MS=1000
MARKET_HISTORY_REPAIR_ENQUEUE_RETRY_MAX_ATTEMPTS=5
MARKET_HISTORY_REPAIR_ENQUEUE_RETRY_DELAY_MS=1000
LEADERBOARD_REFRESH_ENABLED=false
DAU_SUMMARY_ENABLED=true

# Community image upload local defaults. Real S3 credentials are resolved by the AWS SDK
# credential provider chain when presign is used; do not commit secrets here.
AWS_PROFILE=default
S3_BUCKET=coin-zzickmock-community-local-672420933257-ap-southeast-2-an
S3_REGION=ap-southeast-2
S3_KEY_PREFIX=community
COMMUNITY_IMAGE_ALLOWED_MIME=image/png,image/jpeg,image/webp,image/gif
COMMUNITY_IMAGE_MAX_BYTES=5242880
COMMUNITY_IMAGE_PRESIGN_TTL=PT10M
