BACKEND_IMAGE=dockerhub-user/coin-zzickmock-backend:replace-with-release-tag

MYSQL_HOST=mysql.example.internal
MYSQL_PORT=3306
MYSQL_DATABASE=coin_zzickmock
MYSQL_USERNAME=coin_zzickmock
MYSQL_PASSWORD=replace-in-server-env

JWT_SECRET=replace-in-server-env

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-in-server-env

NGINX_PORT=80
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=3001
GRAFANA_ROOT_URL=http://coin-zzickmock.duckdns.org/grafana/

BITGET_WEBSOCKET_ENABLED=true
MARKET_HISTORY_REPAIR_QUEUE_KEY=coin:market:history-repair:events
MARKET_HISTORY_REPAIR_WORKER_ENABLED=true
MARKET_HISTORY_REPAIR_WORKER_FIXED_DELAY_MS=1000
MARKET_HISTORY_REPAIR_WORKER_BLOCK_TIMEOUT_MS=2000
MARKET_HISTORY_REPAIR_PERSISTENCE_RETRY_MAX_ATTEMPTS=5
MARKET_HISTORY_REPAIR_PERSISTENCE_RETRY_DELAY_MS=1000
MARKET_HISTORY_REPAIR_ENQUEUE_RETRY_MAX_ATTEMPTS=5
MARKET_HISTORY_REPAIR_ENQUEUE_RETRY_DELAY_MS=1000
LEADERBOARD_REDIS_ENABLED=true
LEADERBOARD_REFRESH_ENABLED=true
DAU_SUMMARY_ENABLED=true

# Community image upload. AWS credentials must be supplied by the deployment
# environment/instance role; never store AWS secrets in this file.
S3_BUCKET=replace-with-community-image-bucket
S3_REGION=ap-northeast-2
PUBLIC_CDN_BASE_URL=https://cdn.example.com
S3_KEY_PREFIX=community
COMMUNITY_IMAGE_ALLOWED_MIME=image/png,image/jpeg,image/webp,image/gif
COMMUNITY_IMAGE_ALLOWED_SRC_PREFIXES=https://cdn.example.com/
COMMUNITY_IMAGE_MAX_BYTES=5242880
COMMUNITY_IMAGE_PRESIGN_TTL=PT10M
