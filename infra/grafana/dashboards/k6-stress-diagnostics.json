    {
      "id": 7,
      "title": "DB Connection Wait / Timeout",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 4,
        "w": 8,
        "h": 6
      },
      "targets": [
        {
          "expr": "sum by (pool) (rate(hikaricp_connections_acquire_seconds_sum{job=\"$backend_job\"}[$__rate_interval])) / clamp_min(sum by (pool) (rate(hikaricp_connections_acquire_seconds_count{job=\"$backend_job\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{pool}} acquire avg",
          "refId": "A"
        },
        {
          "expr": "max by (pool) (hikaricp_connections_acquire_seconds_max{job=\"$backend_job\"})",
          "legendFormat": "{{pool}} acquire max",
          "refId": "B"
        },
        {
          "expr": "max by (pool) (hikaricp_connections_usage_seconds_max{job=\"$backend_job\"})",
          "legendFormat": "{{pool}} usage max",
          "refId": "C"
        },
        {
          "expr": "sum by (pool) (rate(hikaricp_connections_timeout_total{job=\"$backend_job\"}[$__rate_interval]))",
          "legendFormat": "{{pool}} timeout/s",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Average/max acquire time shows DB connection wait. Usage max shows long-held borrowed connections. Timeout rate should remain zero."
    },
