# Copy this file to .env.local for local overrides.
# Do not commit .env.local or real secret values.

# Server-only backend base URL. Do not include /api/futures.
FUTURES_API_BASE_URL=http://127.0.0.1:8080

# Public legacy stock API bases. NEXT_PUBLIC_* values are bundled into the browser.
NEXT_PUBLIC_BASE_URL=https://news-toss.click/api
NEXT_PUBLIC_BASE_URL2=http://43.201.62.55:8080/api

# Set to enabled only when intentionally running MSW in the browser.
NEXT_PUBLIC_API_MOCKING=disabled

# Optional build-time secret for Sentry source map upload.
SENTRY_AUTH_TOKEN=replace-with-vercel-or-local-secret

# Enable Sentry's Next.js build plugin only after verifying Edge Middleware compatibility.
SENTRY_BUILD_PLUGIN_ENABLED=false
