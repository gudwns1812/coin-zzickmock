# Copy to .env only when local defaults need to change.
APP_ENV=local

# Host ports
NGINX_PORT=80
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
LOKI_PORT=3100
MYSQL_PORT=3306
REDIS_PORT=6379

# Local-only credentials. Do not reuse these values outside local development.
MYSQL_ROOT_PASSWORD=test1234
MYSQL_DATABASE=coin_zzickmock
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Backend runtime settings
BITGET_WEBSOCKET_ENABLED=true
LEADERBOARD_REFRESH_ENABLED=false
DAU_SUMMARY_ENABLED=true
