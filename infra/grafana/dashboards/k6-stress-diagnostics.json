  "panels": [
    {
      "id": 1,
      "title": "Backend Up",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "up{job=\"$backend_job\"}",
          "legendFormat": "backend",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "description": "Prometheus scrape health for the backend actuator endpoint."
    },
    {
      "id": 2,
      "title": "HTTP 5xx / sec",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 4,
        "y": 0,
        "w": 4,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum(rate(http_request_total{job=\"$backend_job\",status_family=\"5xx\"}[$__rate_interval]))",
          "legendFormat": "5xx/s",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "reqps"
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": true
      },
      "description": "Server errors during the selected k6 window."
    },
    {
      "id": 3,
      "title": "HTTP Duration by endpoint group (avg/max)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "expr": "sum by (endpoint_group) (rate(http_request_duration_seconds_sum{job=\"$backend_job\"}[$__rate_interval])) / clamp_min(sum by (endpoint_group) (rate(http_request_duration_seconds_count{job=\"$backend_job\"}[$__rate_interval])), 0.001)",
          "legendFormat": "{{endpoint_group}} avg",
          "refId": "A"
        },
        {
          "expr": "max by (endpoint_group) (http_request_duration_seconds_max{job=\"$backend_job\"})",
          "legendFormat": "{{endpoint_group}} max",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 70
              },
              {
                "color": "red",
                "value": 90
              }
            ]
          },
          "unit": "s"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "description": "Current Micrometer timers export count/sum/max, not histogram buckets. Use avg and max to locate slow API groups during k6. If percentile histograms are enabled later, add p95 here."
    },
