BACKEND_IMAGE=dockerhub-user/coin-zzickmock-backend:replace-with-release-tag
PUSH_IMAGE=dockerhub-user/coin-zzickmock-push-app:replace-with-release-tag
BACKEND_CPUS=2.0
BACKEND_MEMORY_LIMIT=1g
# docker-compose.backend.prod.yml prepends the Scouter Java agent options.
# Keep this value for JVM/runtime options only.
BACKEND_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=65.0 -XX:InitialRAMPercentage=25.0 -XX:+ExitOnOutOfMemoryError
# Backend direct/private metrics endpoint. The split backend compose publishes 8080 on all host
# interfaces by default; restrict inbound TCP 8080 to INFRA_EC2_HOST in the cloud security group.
# BACKEND_BIND_ADDRESS=0.0.0.0
BACKEND_PORT=8080
# Backend-host exporters are published locally; production Prometheus scrapes them through
# backend Nginx private relay paths /internal/metrics/node and /internal/metrics/nginx.
# Direct TCP 9100/9113 access is optional and should not be public.
# NODE_EXPORTER_BIND_ADDRESS=0.0.0.0
NODE_EXPORTER_PORT=9100
# NGINX_EXPORTER_BIND_ADDRESS=0.0.0.0
NGINX_EXPORTER_PORT=9113

# Backend-host Scouter collector. Defaults bind to localhost; use an SSH tunnel or
# set SCOUTER_BIND_ADDRESS to a restricted private/operator address when needed.
SCOUTER_COLLECTOR_IMAGE=dockerhub-user/coin-zzickmock-scouter-collector:replace-with-release-tag
SCOUTER_BIND_ADDRESS=127.0.0.1
SCOUTER_WEB_PORT=6180
SCOUTER_COLLECTOR_PORT=6100
SCOUTER_JAVA_OPT=-Xms256m -Xmx512m

# Push-app direct/private metrics endpoint. Restrict inbound TCP 8081 to INFRA_EC2_HOST.
PUSH_BIND_ADDRESS=0.0.0.0
PUSH_PORT=8081
PUSH_CPUS=1.0
PUSH_MEMORY_LIMIT=512m
PUSH_JAVA_TOOL_OPTIONS=-XX:MaxRAMPercentage=65.0 -XX:+ExitOnOutOfMemoryError
PUSH_SERVER_ENABLED=true
PUSH_PUBLISHER_MODE=shadow
PUSH_MARKET_STREAM_KEY=coin:push:market:v1
PUSH_TRADING_STREAM_KEY=coin:push:trading:v1
PUSH_MARKET_CONSUMER_GROUP=push-server-market-v1
PUSH_TRADING_CONSUMER_GROUP=push-server-trading-v1
PUSH_MARKET_MAX_AGE=PT15S
PUSH_TRADING_MAX_AGE=PT5S

# Optional when Grafana/Loki are not on REDIS_HOST.
# GRAFANA_PRIVATE_HOST=10.0.0.20
# LOKI_PUSH_URL=http://10.0.0.20:3100/loki/api/v1/push

# Redis private endpoint. For the current colocated rollback anchor this may remain `redis`.
# In split topology set REDIS_HOST to the infra host private DNS/IP.
# REDIS_PASSWORD is optional and should only be set when Redis auth/ACL is enabled.
# Do not commit the real secret value.
REDIS_HOST=10.0.0.20
REDIS_PORT=6379
REDIS_DATABASE=0
# REDIS_PASSWORD=replace-in-server-env
INFRA_BIND_ADDRESS=10.0.0.20
BACKEND_PRIVATE_HOST=10.0.0.10

MYSQL_HOST=mysql.example.internal
MYSQL_PORT=3306
MYSQL_DATABASE=coin_zzickmock
MYSQL_USERNAME=coin_zzickmock
MYSQL_PASSWORD=replace-in-server-env

JWT_SECRET=replace-in-server-env
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_COOKIE_SAME_SITE=None
# Google OAuth credentials for the backend OAuth login endpoints.
# Store the real values only in the server secret/env file.
GOOGLE_CLIENT_ID=replace-in-server-env
GOOGLE_CLIENT_SECRET=replace-in-server-env

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-in-server-env

NGINX_PORT=80
GRAFANA_PORT=3000
LOKI_PORT=3100

BITGET_WEBSOCKET_ENABLED=true
MARKET_HISTORY_REPAIR_QUEUE_KEY=coin:market:history-repair:events
MARKET_HISTORY_REPAIR_WORKER_ENABLED=true
MARKET_HISTORY_REPAIR_WORKER_FIXED_DELAY_MS=1000
MARKET_HISTORY_REPAIR_WORKER_BLOCK_TIMEOUT_MS=2000
MARKET_HISTORY_REPAIR_PERSISTENCE_RETRY_MAX_ATTEMPTS=5
MARKET_HISTORY_REPAIR_PERSISTENCE_RETRY_DELAY_MS=1000
MARKET_HISTORY_REPAIR_ENQUEUE_RETRY_MAX_ATTEMPTS=5
MARKET_HISTORY_REPAIR_ENQUEUE_RETRY_DELAY_MS=1000
DAU_SUMMARY_ENABLED=true

# Community image upload. AWS credentials must be supplied by the deployment
# environment/instance role; never store AWS secrets in this file.
S3_BUCKET=coin-zzickmock-community-prod-672420933257-ap-southeast-2-an
S3_REGION=ap-southeast-2
S3_KEY_PREFIX=community
COMMUNITY_IMAGE_ALLOWED_MIME=image/png,image/jpeg,image/webp,image/gif
COMMUNITY_IMAGE_MAX_BYTES=5242880
COMMUNITY_IMAGE_PRESIGN_TTL=PT10M
